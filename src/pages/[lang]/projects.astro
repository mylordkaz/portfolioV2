---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import translations from "../../i18n";
import { projects } from "../../data/projects";
import ProjectModal from "../../components/sections/ProjectModal.astro";
import HeroLogo from "../../components/common/HeroLogo.astro";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "ja" } },
		{ params: { lang: "fr" } },
	];
}

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];

const sortedProjects = [...projects].reverse();
---

<Layout title={`${t.projects.title} — Kevin Tim`}>
	<Header />

	<div class="max-w-[960px] mx-auto px-8">
		<!-- Page hero -->
		<div class="relative py-12 md:py-16 border-b border-line overflow-hidden">
			<HeroLogo />
			<div class="inline-flex items-center gap-2 text-xs text-accent tracking-widest mb-5">
				<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
				{t.projects.eyebrow}
			</div>
			<h1 class="font-heading text-4xl md:text-5xl font-medium tracking-tight text-ink leading-tight mb-2">
				{t.projects.title}
			</h1>
			<p class="text-sm text-muted font-light leading-relaxed">
				{t.projects.description}
			</p>
		</div>

		<!-- Projects list -->
		<div class="border-t border-line my-8">
			{sortedProjects.map((project) => (
				<>
					<button
						id={`modal-open-${project.id}`}
						type="button"
						class="proj-row grid grid-cols-[72px_1fr] md:grid-cols-[100px_1fr_auto] gap-5 md:gap-7 items-center py-6 border-b border-line w-full text-left transition-colors duration-150 hover:bg-card hover:-mx-4 hover:px-4 hover:rounded-md cursor-pointer"
					>
						<div class="w-[72px] h-[48px] md:w-[100px] md:h-[68px] rounded-md border border-line overflow-hidden flex-shrink-0" style={project.imageContain ? 'background: #fdfdfd' : ''}>
							<Image
								src={project.image}
								alt={project.title}
								width={200}
								height={136}
								class={`w-full h-full ${project.imageContain ? 'object-contain rounded-md' : 'object-cover'}`}
								format="webp"
								quality={90}
								loading="lazy"
							/>
						</div>
						<div>
							<div class="text-base font-medium text-ink mb-1">
								{project.title}
							</div>
							<div class="text-xs text-muted font-light leading-relaxed mb-2">
								{t.projects[project.descriptionKey]}
							</div>
							<div class="flex flex-wrap gap-1.5">
								{project.tags.map((tag) => (
									<span class="text-[0.68rem] px-2 py-0.5 rounded bg-card text-muted">
										{tag}
									</span>
								))}
							</div>
						</div>
						<span class="hidden md:inline text-xs text-muted hover:text-accent transition-colors whitespace-nowrap">
							{t.projects.viewCta} &rarr;
						</span>
					</button>

					<ProjectModal
						id={project.id}
						title={project.title}
						description={t.projects[project.descriptionKey]}
						detailedDescription={project.detailedDescription}
						technicalDescription={project.technicalDescription}
						image={project.image}
						tags={project.tags}
						link={project.link}
					/>
				</>
			))}
		</div>
	</div>

	<Footer />
</Layout>
