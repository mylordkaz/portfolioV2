---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import translations from "../../i18n";
import { projects } from "../../data/projects";
import HeroLogo from "../../components/common/HeroLogo.astro";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "ja" } },
		{ params: { lang: "fr" } },
	];
}

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];

const latestProject = projects[projects.length - 1];
---

<Layout title="Kevin Tim — Software Engineer">
	<Header />
	<div class="max-w-[960px] mx-auto px-8">

		<!-- Hero -->
		<section class="relative py-24 border-b border-line overflow-hidden">
			<HeroLogo />
			<div class="inline-flex items-center gap-2 text-xs text-accent tracking-widest mb-6">
				<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
				{t.hero.eyebrow}
			</div>

			<h1 class="font-heading text-5xl md:text-6xl font-medium leading-tight tracking-tight text-ink max-w-[580px] mb-5">
				{t.hero.title}
			</h1>

			<p class="text-base text-muted font-light leading-relaxed max-w-[400px] mb-10">
				{t.hero.description}
			</p>

			<div class="flex items-center gap-5 mb-16">
				<a
					href={`/${lang}/projects`}
					class="bg-ink text-surface text-sm px-5 py-2.5 rounded hover:bg-accent transition-colors"
				>
					{t.hero.ctaProjects}
				</a>
				<a
					href={`/${lang}/about`}
					class="text-sm text-muted hover:text-accent transition-colors"
				>
					{t.hero.ctaContact} &rarr;
				</a>
			</div>

			<div class="flex flex-wrap gap-8 md:gap-14">
				<div>
					<div class="text-[0.68rem] text-faint tracking-widest mb-1">{t.hero.statProjects}</div>
					<span class="font-heading text-xl text-ink">5+</span>
				</div>
				<div>
					<div class="text-[0.68rem] text-faint tracking-widest mb-1">{t.hero.statStack}</div>
					<span class="font-heading text-xl text-ink">{t.hero.statStackValue}</span>
				</div>
				<div>
					<div class="text-[0.68rem] text-faint tracking-widest mb-1">{t.hero.statBased}</div>
					<span class="font-heading text-xl text-ink">{t.hero.statBasedValue}</span>
				</div>
			</div>
		</section>

		<!-- Section header -->
		<div class="flex items-baseline justify-between py-8 border-b border-line mb-8">
			<h2 class="font-heading text-3xl font-medium text-ink tracking-tight">
				{t.section.title}
			</h2>
			<a
				href={`/${lang}/projects`}
				class="text-xs text-muted hover:text-accent transition-colors"
			>
				{t.section.viewAll} &rarr;
			</a>
		</div>

		<!-- Featured project -->
		<div class="mb-16">
			<div class="flex items-start gap-4 mb-3">
				<div class="w-12 h-12 rounded-lg border border-line overflow-hidden flex-shrink-0">
					<Image
						src={latestProject.image}
						alt={latestProject.title}
						width={96}
						height={96}
						class="w-full h-full object-cover"
						format="webp"
						quality={95}
					/>
				</div>
				<div>
					<div class="text-[0.68rem] tracking-widest text-faint mb-1">
						{t.featured.label}
					</div>
					<div class="font-heading text-xl font-medium text-ink tracking-tight">
						{latestProject.title}
					</div>
				</div>
			</div>
			<p class="text-sm text-muted font-light leading-relaxed mb-4">
				{t.projects[latestProject.descriptionKey]}
			</p>
			<div class="flex flex-wrap gap-1.5 mb-4">
				{latestProject.tags.map((tag) => (
					<span class="text-[0.68rem] px-2 py-0.5 rounded bg-card text-muted">
						{tag}
					</span>
				))}
			</div>
			<a
				href={`/${lang}/projects`}
				class="text-sm text-ink inline-flex items-center gap-1.5 border-b border-ink pb-0.5 hover:text-accent hover:border-accent transition-colors"
			>
				{t.featured.viewProject} &rarr;
			</a>
		</div>

	</div>
	<Footer />
</Layout>
