---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import translations from "../../i18n";
import HeroLogo from "../../components/common/HeroLogo.astro";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "ja" } },
		{ params: { lang: "fr" } },
	];
}

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];
---

<Layout title={`${t.expertise.title} — Kevin Tim`}>
	<Header />

	<div class="max-w-[960px] mx-auto px-8">
		<!-- Page hero -->
		<div class="relative py-12 md:py-16 border-b border-line overflow-hidden">
			<HeroLogo />
			<div class="inline-flex items-center gap-2 text-xs text-accent tracking-widest mb-5">
				<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
				{t.expertise.eyebrow}
			</div>
			<h1 class="font-heading text-4xl md:text-5xl font-medium tracking-tight text-ink leading-tight mb-2">
				{t.expertise.title}
			</h1>
			<p class="text-sm text-muted font-light leading-relaxed max-w-[420px]">
				{t.expertise.description}
			</p>
		</div>

		<!-- Offers list -->
		<div class="mb-20">
			{t.expertise.offers.map((offer, i) => (
				<div class:list={[
					"grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 items-start py-10 border-b border-line",
					i === 0 && "border-t border-line mt-10",
				]}>
					<div>
						<div class="text-[0.68rem] tracking-widest text-faint mb-2">
							{String(i + 1).padStart(2, "0")}
						</div>
						<div class="font-heading text-2xl font-medium text-ink leading-snug tracking-tight">
							{offer.title}
						</div>
					</div>
					<div>
						<p class="text-sm text-muted font-light leading-relaxed mb-5">
							{offer.description}
						</p>
						<div class="flex flex-col gap-2">
							{offer.bullets.map((bullet) => (
								<span class="text-xs text-muted font-light flex items-center gap-2.5">
									<span class="w-[3px] h-[3px] rounded-full bg-accent flex-shrink-0"></span>
									{bullet}
								</span>
							))}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>

	<Footer />
</Layout>
