---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import translations from "../../i18n";
import aboutImg from "../../assets/aboutMe.webp";
import HeroLogo from "../../components/common/HeroLogo.astro";

export function getStaticPaths() {
	return [
		{ params: { lang: "en" } },
		{ params: { lang: "ja" } },
		{ params: { lang: "fr" } },
	];
}

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];
---

<Layout title={`About — Kevin Tim`}>
	<Header />

	<div class="max-w-[960px] mx-auto px-8">
		<!-- About section -->
		<section class="py-12 md:py-16 border-b border-line">
			<div class="relative overflow-hidden pb-12">
				<HeroLogo />
				<div class="inline-flex items-center gap-2 text-xs text-accent tracking-widest mb-5">
					<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
					{t.about.eyebrow}
				</div>
				<h1 class="font-heading text-4xl md:text-5xl font-medium tracking-tight text-ink leading-tight whitespace-pre-line">
					{t.about.heading}
				</h1>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start">
				<!-- Photo -->
				<div class="aspect-[3/4] rounded-lg border border-line overflow-hidden bg-card">
					<Image
						src={aboutImg}
						alt="Kevin Tim"
						width={480}
						height={640}
						class="w-full h-full object-cover"
						format="webp"
						quality={95}
						loading="eager"
					/>
				</div>

				<!-- Bio + facts -->
				<div>
					<div class="mb-8">
						{t.about.bio.map((paragraph) => (
							<p class="text-sm text-muted font-light leading-relaxed mb-3">
								{paragraph}
							</p>
						))}
					</div>
					<div class="border-t border-line">
						{t.about.facts.map((fact) => (
							<div class="flex justify-between py-2.5 border-b border-line text-sm">
								<span class="text-muted">{fact.label}</span>
								<span class="text-ink font-medium">{fact.value}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Contact section -->
		<section class="py-12 md:py-16">
			<div class="inline-flex items-center gap-2 text-xs text-accent tracking-widest mb-5">
				<span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
				{t.about.contact.eyebrow}
			</div>
			<h2 class="font-heading text-3xl md:text-4xl font-medium tracking-tight text-ink leading-tight mb-2">
				{t.about.contact.title}
			</h2>
			<p class="text-sm text-muted font-light leading-relaxed mb-12">
				{t.about.contact.description}
			</p>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
				<!-- Social links -->
				<div>
					<div class="text-[0.68rem] tracking-widest text-faint mb-3">
						{t.about.contact.socialLabel}
					</div>
					<div class="border-t border-line">
						<a
							href="https://github.com/mylordkaz"
							target="_blank"
							rel="noopener noreferrer"
							class="flex justify-between items-center py-3 border-b border-line text-sm text-ink hover:text-accent transition-colors"
						>
							<span>GitHub</span>
							<span class="text-xs text-faint">&rarr;</span>
						</a>
						<a
							href="https://linkedin.com/in/kevin-timsiline"
							target="_blank"
							rel="noopener noreferrer"
							class="flex justify-between items-center py-3 border-b border-line text-sm text-ink hover:text-accent transition-colors"
						>
							<span>LinkedIn</span>
							<span class="text-xs text-faint">&rarr;</span>
						</a>
						<a
							href="https://line.me/ti/p/mylordkaz"
							class="flex justify-between items-center py-3 border-b border-line text-sm text-ink hover:text-accent transition-colors"
						>
							<span>LINE</span>
							<span class="text-xs text-faint">&rarr;</span>
						</a>
						<a
							href="mailto:timsiline.kevin@gmail.com"
							class="flex justify-between items-center py-3 border-b border-line text-sm text-ink hover:text-accent transition-colors"
						>
							<span>Email</span>
							<span class="text-xs text-faint">&rarr;</span>
						</a>
					</div>
				</div>

				<!-- Contact form -->
				<div>
					<div class="text-[0.68rem] tracking-widest text-faint mb-3">
						{t.about.contact.formLabel}
					</div>
					<form
						class="flex flex-col gap-4"
						name="contact"
						method="POST"
						action="https://formspree.io/f/myzedjpj"
					>
						<div>
							<label for="name" class="block text-[0.68rem] tracking-wider text-muted mb-1">
								{t.about.contact.form.name}
							</label>
							<input
								type="text"
								id="name"
								name="name"
								required
								placeholder="Your name"
								class="w-full bg-card border border-line rounded-md px-3 py-2.5 text-sm text-ink placeholder:text-faint outline-none focus:border-muted transition-colors"
							/>
						</div>
						<div>
							<label for="email" class="block text-[0.68rem] tracking-wider text-muted mb-1">
								{t.about.contact.form.email}
							</label>
							<input
								type="email"
								id="email"
								name="email"
								required
								placeholder="your@email.com"
								class="w-full bg-card border border-line rounded-md px-3 py-2.5 text-sm text-ink placeholder:text-faint outline-none focus:border-muted transition-colors"
							/>
						</div>
						<div>
							<label for="message" class="block text-[0.68rem] tracking-wider text-muted mb-1">
								{t.about.contact.form.message}
							</label>
							<textarea
								id="message"
								name="message"
								required
								rows="4"
								placeholder="Tell me about your project..."
								class="w-full bg-card border border-line rounded-md px-3 py-2.5 text-sm text-ink placeholder:text-faint outline-none focus:border-muted transition-colors resize-none"
							></textarea>
						</div>
						<div id="form-status" class="hidden">
							<p id="success-message" class="text-green-600 dark:text-green-400 text-sm hidden">
								{t.about.contact.form.success}
							</p>
							<p id="error-message" class="text-red-600 dark:text-red-400 text-sm hidden">
								{t.about.contact.form.error}
							</p>
						</div>
						<button
							type="submit"
							id="submit-button"
							class="self-start bg-ink text-surface text-sm px-5 py-2.5 rounded-md hover:bg-accent transition-colors cursor-pointer"
						>
							{t.about.contact.form.submit}
						</button>
					</form>
				</div>
			</div>
		</section>
	</div>

	<Footer />
</Layout>

<script>
	const handleSubmit = async (event: Event) => {
		event.preventDefault();

		const form = event.target as HTMLFormElement;
		const submitButton = form.querySelector("#submit-button") as HTMLButtonElement;
		const formStatus = document.getElementById("form-status");
		const successMessage = document.getElementById("success-message");
		const errorMessage = document.getElementById("error-message");

		const originalButtonText = submitButton.innerHTML;

		try {
			submitButton.disabled = true;
			submitButton.innerHTML = "Sending...";

			const response = await fetch(form.action, {
				method: "POST",
				body: new FormData(form),
				headers: { Accept: "application/json" },
			});

			if (response.ok) {
				form.reset();
				formStatus?.classList.remove("hidden");
				successMessage?.classList.remove("hidden");
				errorMessage?.classList.add("hidden");
				setTimeout(() => {
					formStatus?.classList.add("hidden");
					successMessage?.classList.add("hidden");
				}, 5000);
			} else {
				throw new Error("Form submission failed");
			}
		} catch (error) {
			formStatus?.classList.remove("hidden");
			errorMessage?.classList.remove("hidden");
			successMessage?.classList.add("hidden");
			setTimeout(() => {
				formStatus?.classList.add("hidden");
				errorMessage?.classList.add("hidden");
			}, 5000);
		} finally {
			submitButton.disabled = false;
			submitButton.innerHTML = originalButtonText;
		}
	};

	document
		.querySelector('form[name="contact"]')
		?.addEventListener("submit", handleSubmit);
</script>
