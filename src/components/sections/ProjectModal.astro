---
import { Image } from "astro:assets";
import translations from "../../i18n";
import type { ProjectModalProps } from "../../types/project";

const {
	id,
	title,
	detailedDescription,
	technicalDescription,
	image,
	tags,
	link,
} = Astro.props as ProjectModalProps;

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];
---

<div
	id={`modal-${id}`}
	class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300"
	role="dialog"
	aria-labelledby={`modal-title-${id}`}
	aria-modal="true"
>
	<div class="fixed inset-0 bg-black/50 transition-opacity"></div>

	<div class="fixed inset-0 z-10 overflow-y-auto">
		<div class="flex min-h-full items-center justify-center p-4 sm:p-0">
			<div
				class="modal-content relative w-full transform overflow-hidden bg-surface text-left shadow-xl transition-all sm:my-8 sm:max-w-4xl h-full sm:h-auto max-h-[100vh] sm:max-h-[90vh] sm:rounded-lg"
			>
				<!-- Close button -->
				<button
					type="button"
					class="modal-close fixed sm:absolute right-4 top-4 z-20 rounded-full bg-card p-2.5 transition-colors hover:opacity-70 shadow-lg"
					aria-label="Close modal"
				>
					<svg
						class="h-5 w-5 text-muted"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>

				<!-- Content wrapper -->
				<div class="max-h-[100vh] sm:max-h-[90vh] overflow-y-auto">
					<div class="sticky top-0 bg-surface z-10 p-6 border-b border-line">
						<h3 class="font-heading text-2xl font-medium text-ink tracking-tight">
							{title}
						</h3>
					</div>

					<div class="space-y-6 p-6">
						<div class="max-w-2xl mx-auto">
							<div class="relative max-h-[300px] w-full flex items-center justify-center rounded-lg p-4">
								<Image
									src={image}
									alt={title}
									width={1200}
									height={675}
									class="max-h-[250px] w-auto object-contain rounded-lg"
								/>
							</div>
						</div>

						<div class="space-y-3">
							<h4 class="text-sm font-medium text-ink tracking-wide">{t.projects.modal.about}</h4>
							<p class="text-sm text-muted font-light leading-relaxed">
								{t.projects[detailedDescription]}
							</p>
						</div>

						<div class="space-y-3">
							<h4 class="text-sm font-medium text-ink tracking-wide">{t.projects.modal.technical}</h4>
							<p class="text-sm text-muted font-light leading-relaxed">
								{t.projects[technicalDescription]}
							</p>
						</div>

						<div class="flex flex-wrap gap-1.5">
							{tags.map((tag) => (
								<span class="text-[0.7rem] px-2.5 py-1 rounded bg-card text-muted">
									{tag}
								</span>
							))}
						</div>

						{link && (
							<div class="flex justify-end">
								<a
									href={link}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-2 text-sm text-ink border-b border-ink pb-0.5 hover:text-accent hover:border-accent transition-colors"
								>
									{t.projects.modal.visitbtn}
									<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
									</svg>
								</a>
							</div>
						)}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	import { modalManager } from "../../scripts/modal";

	modalManager.init();
	document.addEventListener("astro:page-load", () => {
		modalManager.init();
	});
</script>
