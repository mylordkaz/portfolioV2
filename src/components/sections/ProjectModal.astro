---
import { Image } from "astro:assets";
import translations from "../../i18n";
import type { ProjectModalProps } from "../../types/project";

const {
	id,
	title,
	detailedDescription,
	technicalDescription,
	image,
	galleryImages = [],
	tags,
	link,
} = Astro.props as ProjectModalProps;

const currentPath = Astro.url.pathname;
const lang = currentPath.split("/")[1] || "en";
const t = translations[lang as keyof typeof translations];
---

<div
	id={`modal-${id}`}
	class="fixed inset-0 z-50 hidden opacity-0 transition-opacity duration-300"
	role="dialog"
	aria-labelledby={`modal-title-${id}`}
	aria-modal="true"
>
	<div class="fixed inset-0 bg-black/50 transition-opacity"></div>

	<div class="fixed inset-0 z-10 overflow-y-auto">
		<div class="flex min-h-full items-center justify-center p-4 sm:p-0">
			<div
				class="modal-content relative w-full transform overflow-hidden bg-surface text-left shadow-xl transition-all sm:my-8 sm:max-w-4xl h-full sm:h-auto max-h-[100vh] sm:max-h-[90vh] sm:rounded-lg"
			>
				<!-- Close button -->
				<button
					type="button"
					class="modal-close fixed sm:absolute right-4 top-4 z-20 rounded-full bg-card p-2.5 transition-colors hover:opacity-70 shadow-lg"
					aria-label="Close modal"
				>
					<svg
						class="h-5 w-5 text-muted"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2"
						stroke="currentColor"
					>
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>

				<!-- Content wrapper -->
				<div class="max-h-[100vh] sm:max-h-[90vh] overflow-y-auto">
					<div class="sticky top-0 bg-surface z-10 p-6 border-b border-line">
						<h3 class="font-serif text-2xl font-medium text-ink tracking-tight">
							{title}
						</h3>
					</div>

					<div class="space-y-6 p-6">
						<div class="max-w-2xl mx-auto">
							<div class="relative max-h-[300px] w-full flex items-center justify-center rounded-lg p-4">
								<Image
									src={image}
									alt={title}
									width={1200}
									height={675}
									class="max-h-[250px] w-auto object-contain rounded-lg"
								/>
							</div>
						</div>

						<div class="space-y-3">
							<h4 class="text-sm font-medium text-ink tracking-wide">{t.projects.modal.about}</h4>
							<p class="text-sm text-muted font-light leading-relaxed">
								{t.projects[detailedDescription]}
							</p>
						</div>

						<div class="space-y-3">
							<h4 class="text-sm font-medium text-ink tracking-wide">{t.projects.modal.technical}</h4>
							<p class="text-sm text-muted font-light leading-relaxed">
								{t.projects[technicalDescription]}
							</p>
						</div>

						{galleryImages.length > 0 && (
							<div class="space-y-3">
								<h4 class="text-sm font-medium text-ink tracking-wide">{t.projects.modal.gallery}</h4>
								<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
									{galleryImages.map((img, index) => (
										<div class="group relative overflow-hidden rounded-md border border-line">
											<div class="aspect-video">
												<Image
													src={img}
													alt={`${title} gallery image ${index + 1}`}
													width={600}
													height={400}
													class="w-full h-full object-contain"
													format="webp"
													quality={90}
													loading="lazy"
												/>
											</div>
											<button
												class="expand-image absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition-all group-hover:bg-black/40 group-hover:opacity-100"
												aria-label="View full image"
												data-image-src={img.src}
												data-image-alt={`${title} gallery image ${index + 1}`}
											>
												<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
													<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m4-3H6" />
												</svg>
											</button>
										</div>
									))}
								</div>
							</div>
						)}

						<div class="flex flex-wrap gap-1.5">
							{tags.map((tag) => (
								<span class="text-[0.7rem] px-2.5 py-1 rounded bg-card text-muted">
									{tag}
								</span>
							))}
						</div>

						{link && (
							<div class="flex justify-end">
								<a
									href={link}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-2 text-sm text-ink border-b border-ink pb-0.5 hover:opacity-60 transition-opacity"
								>
									{t.projects.modal.visitbtn}
									<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
									</svg>
								</a>
							</div>
						)}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<div
	id="fullscreen-viewer"
	class="fixed inset-0 z-[100] hidden bg-black/65"
	role="dialog"
	aria-modal="true"
>
	<button
		id="close-fullscreen"
		class="absolute right-4 top-4 z-[110] rounded-full p-2 text-white hover:bg-white/10"
	>
		<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
		</svg>
	</button>

	<div class="h-full w-full flex items-center justify-center p-4">
		<img
			id="fullscreen-image"
			src=""
			alt=""
			class="max-h-[90vh] max-w-[90vw] object-contain"
		/>
	</div>
</div>

<script>
	import { modalManager } from "../../scripts/modal";

	modalManager.init();
	document.addEventListener("astro:page-load", () => {
		modalManager.init();
	});
</script>
