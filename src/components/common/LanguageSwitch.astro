---
const currentLang = Astro.url.pathname.split("/")[1] || "en";
const currentPath = Astro.url.pathname.split("/").slice(2).join("/");
const languages = ["en", "ja", "fr"] as const;
---

<div class="flex items-center gap-1 text-xs tracking-wide">
	{languages.map((code, i) => (
		<>
			<a
				href={`/${code}${currentPath ? `/${currentPath}` : ""}`}
				class:list={[
					"uppercase transition-colors duration-150",
					currentLang === code
						? "text-ink font-medium"
						: "text-faint hover:text-muted",
				]}
			>
				{code}
			</a>
			{i < languages.length - 1 && (
				<span class="text-faint">/</span>
			)}
		</>
	))}
</div>
